  m_Name: BlyondaQuestData
  m_EditorClassIdentifier: Assembly-CSharp::QuestData
  <Name>k__BackingField: "\u041E\u0441\u0432\u0435\u0442\u0438\u0442\u044C \u043F\u0443\u0442\u044C"
  <Description>k__BackingField: "\u0412 \u043B\u0435\u0441\u0443 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0442\u0435\u043C\u043D\u043E. \u041D\u0443\u0436\u043D\u043E \u0447\u0442\u043E-\u0442\u043E,
    \u0447\u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u043E\u0441\u0432\u0435\u0442\u0438\u0442\u044C
    \u0434\u043E\u0440\u043E\u0433\u0443."
  <StartPhrase>k__BackingField: {fileID: 0}
  <StartPhraseText>k__BackingField: "\u041C\u043D\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E.
    \u0412 \u043B\u0435\u0441\u0443-\u0442\u043E \u0442\u0451\u043C\u043D\u043E \u043E\u0447\u0435\u043D\u044C.
    \u041C\u043E\u0436\u0435\u0442, \u0443 \u043D\u0430\u0441 \u0435\u0441\u0442\u044C
    \u0432 \u0441\u0443\u043C\u0435 \u0447\u0442\u043E-\u0442\u043E \u0441\u0432\u0435\u0442\u044F\u0449\u0435\u0435\u0441\u044F?"
  <EndPhrase>k__BackingField: {fileID: 0}
  <EndPhraseText>k__BackingField: "\u0422\u0435\u043F\u0435\u0440\u044C \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u043B\u0443\u0447\u0448\u0435! \u041C\u043E\u0436\u043D\u043E \u0438\u0434\u0442\u0438
    \u0434\u0430\u043B\u044C\u0448\u0435."
