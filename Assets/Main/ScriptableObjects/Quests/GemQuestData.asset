  <Name>k__BackingField: "\u041D\u0430\u0439\u0442\u0438 \u043C\u0430\u043B\u0430\u0445\u0438\u0442"
  <Description>k__BackingField: "\u041D\u0430\u0439\u0434\u0438 \u043C\u0430\u043B\u0430\u0445\u0438\u0442
    - \u043A\u0430\u043C\u0435\u043D\u044C \u0446\u0432\u0435\u0442\u0430 \u043C\u043E\u0440\u0441\u043A\u043E\u0439
    \u0432\u043E\u043B\u043D\u044B."
  <StartPhrase>k__BackingField: {fileID: 0}
  <StartPhraseText>k__BackingField: "\u0413\u0434\u0435-\u0442\u043E \u0437\u0434\u0435\u0441\u044C
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u043C\u0430\u043B\u0430\u0445\u0438\u0442.
    \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u043E\u043D \u0442\u0435\u0431\u0435
    \u0438 \u043D\u0443\u0436\u0435\u043D"
  <EndPhrase>k__BackingField: {fileID: 0}
  <EndPhraseText>k__BackingField: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u0447\u0442\u043E
    \u043F\u043E\u043C\u043E\u0433! \u0414\u043E \u0441\u0432\u0438\u0434\u0430\u043D\u0438\u044F!"
