  <Name>k__BackingField: "\u041F\u043E\u0438\u0441\u043A \u043C\u0430\u043B\u0430\u0445\u0438\u0442\u0430"
  <Description>k__BackingField: "\u041D\u0430\u0439\u0434\u0438\u0442\u0435 \u043C\u0430\u043B\u0430\u0445\u0438\u0442
    \u0438 \u043F\u043E\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u0435\u0433\u043E
    \u043D\u0430 \u043F\u0435\u043D\u0451\u043A. \u041F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0430
    \u0435\u0441\u0442\u044C \u0432 \u0441\u043B\u043E\u0432\u0430\u0440\u0435. "
  <CompleteMessage>k__BackingField: "\u0411\u0430\u0436\u043E\u0432 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u0430\u0445\u0430\u0438\u0442 \u0438 \u043E\u0442\u043A\u0440\u044B\u043B
    \u0432\u0430\u043C \u043F\u043E\u0440\u0442\u0430\u043B, \u0447\u0442\u043E\u0431\u044B
    \u0412\u044B \u043C\u043E\u0433\u043B\u0438 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u043A \u043D\u0435\u043C\u0443 \u043E\u0431\u0440\u0442\u0430\u043D\u043E."
