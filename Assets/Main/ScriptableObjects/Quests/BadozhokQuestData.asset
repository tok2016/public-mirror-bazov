  m_Name: BadozhokQuestData
  m_EditorClassIdentifier: Assembly-CSharp::QuestData
  <Name>k__BackingField: "\u041F\u0435\u0440\u0435\u0445\u043E\u0434 \u0447\u0435\u0440\u0435\u0437
    \u0441\u0443\u0433\u0440\u043E\u0431"
  <Description>k__BackingField: "\u041D\u0430 \u043F\u0443\u0442\u0438 - \u0441\u0443\u0433\u0440\u043E\u0431.
    \u0412 \u043D\u0451\u043C \u043C\u043E\u0436\u043D\u043E \u0443\u0433\u0440\u0443\u0437\u043D\u0443\u0442\u044C.
    \u041D\u0443\u0436\u043D\u043E \u0447\u0442\u043E-\u0442\u043E, \u043D\u0430
    \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0435\u0440\u0435\u0442\u044C\u0441\u044F.
    \u041D\u0430\u0437\u043E\u0432\u0438\u0442\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442
    \u0432 \u043C\u0438\u043A\u0440\u043E\u0444\u043E\u043D - \u0438 \u043E\u043D
    \u0442\u043E\u0436\u0435 \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F \u0432
    \u0440\u0443\u043A\u0435."
  <CompleteMessage>k__BackingField: "\u0411\u0430\u0434\u043E\u0436\u043E\u043A \u043F\u043E\u043C\u043E\u0433
    \u043F\u0440\u043E\u0439\u0442\u0438 \u0447\u0435\u0440\u0435\u0437 \u0441\u0443\u0433\u0440\u043E\u0431.
    \u0412\u043F\u0435\u0440\u0435\u0434\u0438 - \u043F\u043E\u043B\u044F\u043D\u0430.
    \u041C\u043E\u0436\u0435\u0442, \u0442\u0443\u0434\u0430 \u0441\u043F\u0440\u044F\u0442\u0430\u043B\u0441\u044C
    \u041C\u0443\u0440\u0451\u043D\u043A\u0430?"
