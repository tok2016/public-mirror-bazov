  <Priority>k__BackingField: 2
  <Text>k__BackingField: "\u0412\u043E\u0442 \u0438 \u043B\u0430\u0434\u043D\u043E.
    \u041F\u043E\u043C\u043E\u0433\u0438 \u0414\u0430\u0440\u0451\u043D\u043A\u0435
    \u041C\u0443\u0440\u0451\u043D\u043A\u0443 \u0441\u044B\u0441\u043A\u0430\u0442\u044C,
    \u0441\u043B\u043E\u0432\u0430 \u0443\u0440\u0430\u043B\u044C\u0441\u043A\u0438\u0435
    \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0439, \u0430 \u043A\u0430\u043A
    \u043A\u043E\u0437\u043B\u0438\u043A\u0430 \u043D\u0430\u0439\u0434\u0451\u0448\u044C
    - \u043C\u0430\u043B\u0430\u0445\u0438\u0442 \u043F\u0440\u0438\u043D\u0435\u0441\u0438.
    \u041E\u043D \u0437\u0435\u043B\u0451\u043D\u044B\u0439, \u0441 \u0442\u0451\u043C\u043D\u044B\u043C\u0438
    \u0443\u0437\u043E\u0440\u0430\u043C\u0438, \u043D\u0435 \u043E\u0448\u0438\u0431\u0438\u0441\u044C.
    \u0421\u0442\u0443\u043F\u0430\u0439 - \u0414\u0430\u0440\u0451\u043D\u043A\u0430
    \u0436\u0434\u0451\u0442."
  <Word>k__BackingField: {fileID: 0}
