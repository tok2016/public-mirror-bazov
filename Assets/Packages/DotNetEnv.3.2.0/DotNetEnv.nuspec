<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>DotNetEnv</id>
    <version>3.2.0</version>
    <title>DotNetEnv</title>
    <authors>DotNetEnv</authors>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/tonerdo/dotnet-env</projectUrl>
    <description>A .NET library to load environment variables from .env files</description>
    <tags>dotnet env dotfiles</tags>
    <repository type="git" url="https://github.com/tonerdo/dotnet-env" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Extensions.Configuration" version="1.1.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="1.1.2" exclude="Build,Analyzers" />
        <dependency id="Superpower" version="3.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>